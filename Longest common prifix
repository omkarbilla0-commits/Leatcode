public class Solution {

    /**
     * Finds the longest common prefix string amongst an array of strings.
     * If there is no common prefix, returns an empty string "".
     *
     * @param strs The array of strings.
     * @return The longest common prefix, or "" if none exists.
     */
    public String longestCommonPrefix(String[] strs) {
        if (strs == null || strs.length == 0) {
            return "";
        }

        // Iterate through each character of the first string
        for (int i = 0; i < strs[0].length(); i++) {
            char currentChar = strs[0].charAt(i);

            // Compare this character with the character at the same position in all other strings
            for (int j = 1; j < strs.length; j++) {
                // If the current string is shorter or the characters don't match, 
                // the common prefix ends here. Return the prefix found so far.
                if (i == strs[j].length() || strs[j].charAt(i) != currentChar) {
                    return strs[0].substring(0, i);
                }
            }
        }

        // If the loop completes without finding a mismatch, 
        // the entire first string is the common prefix.
        return strs[0];
    }

    public static void main(String[] args) {
        Solution solution = new Solution();

        // Example 1: Common prefix "fl"
        String[] input1 = {"flower", "flow", "flight"};
        System.out.println("Input: [\"flower\", \"flow\", \"flight\"]");
        System.out.println("Longest Common Prefix: \"" + solution.longestCommonPrefix(input1) + "\""); // Output: "fl"

        // Example 2: No common prefix
        String[] input2 = {"dog", "racecar", "car"};
        System.out.println("\nInput: [\"dog\", \"racecar\", \"car\"]");
        System.out.println("Longest Common Prefix: \"" + solution.longestCommonPrefix(input2) + "\""); // Output: ""
    }
}
